# Ambiente: development | production
APP_ENV=development

# Endereço HTTP do servidor
HTTP_ADDR=:8080

# Conexão Postgres (pgx aceita postgres:// e postgresql://)
DATABASE_URL=postgres://encurtador:encurtador@localhost:5455/encurtador?sslmode=disable

# URL base usada para montar o link curto (sem barra no final)
BASE_URL=http://localhost:8080

# API key single-tenant (protege os endpoints /api/*)
API_KEY=dev-api-key-change-me

# Salt para hashear o IP do clique (NUNCA persistir IP cru)
IP_HASH_SALT=troque-este-salt

# Caminho do banco GeoLite2-City (.mmdb) — baixar manualmente
GEOLITE_DB_PATH=./data/GeoLite2-City.mmdb
